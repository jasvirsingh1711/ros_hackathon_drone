<?xml version="1.0"?>
<robot name="red_gate">
  
  <gazebo>
    <static>true</static>
  </gazebo>

  <link name="base_link">
    <inertial>
      <mass value="10.0"/>
      <origin xyz="0 0 0.5" rpy="0 0 0"/>
      <inertia ixx="1.0" ixy="0.0" ixz="0.0" iyy="1.0" iyz="0.0" izz="1.0"/>
    </inertial>

    <visual>
      <origin xyz="0 0.5 0.5" rpy="0 0 0"/>
      <geometry><box size="0.1 0.1 1.0"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0.5 0.5" rpy="0 0 0"/>
      <geometry><box size="0.1 0.1 1.0"/></geometry>
    </collision>

    <visual>
      <origin xyz="0 -0.5 0.5" rpy="0 0 0"/>
      <geometry><box size="0.1 0.1 1.0"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 -0.5 0.5" rpy="0 0 0"/>
      <geometry><box size="0.1 0.1 1.0"/></geometry>
    </collision>

    <visual>
      <origin xyz="0 0 1.05" rpy="0 0 0"/>
      <geometry><box size="0.1 1.1 0.1"/></geometry>
    </visual>
    <collision>
      <origin xyz="0 0 1.05" rpy="0 0 0"/>
      <geometry><box size="0.1 1.1 0.1"/></geometry>
    </collision>
  </link>

  <gazebo reference="base_link">
    <material>Gazebo/Red</material>
  </gazebo>
</robot>
